# ===========================================
#      Solebid Docker Environment Variables
# ===========================================
# 이 파일은 환경 변수 템플릿입니다.
# 실제 사용을 위해 이 파일을 .env로 복사하고 실제 값으로 수정하세요.

# ===========================================
#      Redis Configuration
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
#      Database Configuration
# ===========================================
# 로컬 MySQL 연결 정보 (Docker 환경)
DB_URL=jdbc:mysql://mysql:3306/solebid?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true
DB_USERNAME=solebid
DB_PASSWORD=solebidpassword

# MySQL Docker 설정
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=solebid
MYSQL_USER=solebid
MYSQL_PASSWORD=solebidpassword

# ===========================================
#      JWT Configuration
# ===========================================
# JWT 토큰 서명을 위한 비밀 키 (최소 64바이트 권장)
JWT_SECRET=your-super-secure-and-long-secret-key-for-jwt-signing
JWT_ACCESS_TOKEN_VALIDITY=3600
JWT_REFRESH_TOKEN_VALIDITY=86400

# ===========================================
#      AWS Configuration
# ===========================================
# AWS 서비스 접근을 위한 자격 증명
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-2
S3_BUCKET=your-s3-bucket-name

# ===========================================
#      Email Configuration
# ===========================================
# Gmail SMTP 설정
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_DEBUG=false

# Gmail OAuth2 설정
GOOGLE_MAIL_REFRESH_TOKEN=your-google-mail-refresh-token

# ===========================================
#      OAuth2 Configuration (Docker Environment)
# ===========================================
# Google OAuth2 설정 - Docker 환경에서는 포트 3000 사용
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# Kakao OAuth2 설정 - Docker 환경에서는 포트 3000 사용
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:3000/auth/callback/kakao
KAKAO_API_HOST=https://kapi.kakao.com
KAKAO_ADMIN_KEY=your-kakao-admin-key

# 참고: 로컬 개발 환경(Vite)에서는 포트 5173을 사용하므로
# 개발 시에는 다음 URL을 OAuth 제공자에 등록해야 합니다:
# - Google: http://localhost:5173/auth/callback/google
# - Kakao: http://localhost:5173/auth/callback/kakao

# ===========================================
#      PortOne Configuration
# ===========================================
# PortOne 결제 서비스 설정
PORTONE_BASE_URL=https://api.iamport.kr
PORTONE_API_KEY=your-portone-api-key
PORTONE_API_SECRET=your-portone-api-secret

# ===========================================
#      Application Configuration
# ===========================================
# 프론트엔드 URL 설정
FRONTEND_BASE_URL=http://localhost:5173

# 서버 설정
SERVER_PORT=8080

# ===========================================
#      Docker Port Configuration
# ===========================================
# Docker 개발환경 포트 설정 (충돌 방지를 위해 변경 가능)
DOCKER_FRONTEND_PORT=3000
DOCKER_FRONTEND_HTTPS_PORT=3443
DOCKER_BACKEND_PORT=8080
DOCKER_MYSQL_PORT=3306
DOCKER_REDIS_PORT=6379
DOCKER_DEBUG_PORT=5005
DOCKER_LIVERELOAD_PORT=35729

# ===========================================
#      SSL/HTTPS Configuration
# ===========================================
# HTTPS 활성화 여부 (개발 환경)
NGINX_SSL_ENABLED=false

# SSL 인증서 경로 (컨테이너 내부 경로)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem



# ===========================================
#      Spring Boot Configuration
# ===========================================
# Docker 환경에서 사용할 Spring 프로파일
SPRING_PROFILES_ACTIVE=docker,redis

# ===========================================
#      Logging Configuration
# ===========================================
# 로깅 레벨 설정
SECURITY_LOG_LEVEL=info
APP_LOG_LEVEL=info
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false