# Solebid 프로덕션 환경 변수 템플릿
# 실제 프로덕션 배포 시 .env.prod 파일로 복사하여 사용

# ===========================================
# 기본 애플리케이션 설정
# ===========================================
SPRING_PROFILES_ACTIVE=prod,redis
TZ=Asia/Seoul

# 프로덕션 도메인 설정
FRONTEND_BASE_URL=https://your-domain.com
SERVER_PORT=8080

# ===========================================
# 데이터베이스 설정 (AWS RDS)
# ===========================================
DB_URL=jdbc:mysql://your-rds-endpoint:3306/solebid?useSSL=true&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true
DB_USERNAME=your-db-username
DB_PASSWORD=your-secure-db-password

# ===========================================
# Redis 설정 (보안 강화)
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-very-secure-redis-password-min-32-chars

# Redis 데이터 저장 경로 (호스트 경로)
REDIS_DATA_PATH=/opt/solebid/data/redis

# ===========================================
# JWT 설정 (프로덕션용 보안 강화)
# ===========================================
JWT_SECRET=your-super-secure-jwt-secret-key-must-be-at-least-64-bytes-long-for-production-security-requirements
JWT_ACCESS_TOKEN_VALIDITY=1800    # 30분 (보안 강화)
JWT_REFRESH_TOKEN_VALIDITY=604800 # 7일

# ===========================================
# AWS 설정
# ===========================================
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-2
S3_BUCKET=your-s3-bucket-name

# ===========================================
# 이메일 설정
# ===========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_DEBUG=false
GOOGLE_MAIL_REFRESH_TOKEN=your-google-mail-refresh-token

# ===========================================
# OAuth2 설정 - Google (프로덕션 도메인)
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/callback/google

# ===========================================
# OAuth2 설정 - Kakao (프로덕션 도메인)
# ===========================================
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=https://your-domain.com/auth/callback/kakao
KAKAO_API_HOST=https://kapi.kakao.com
KAKAO_ADMIN_KEY=your-kakao-admin-key

# ===========================================
# PortOne 결제 설정
# ===========================================
PORTONE_BASE_URL=https://api.iamport.kr
PORTONE_API_KEY=your-portone-api-key
PORTONE_API_SECRET=your-portone-api-secret

# ===========================================
# 로깅 설정 (프로덕션 최적화)
# ===========================================
SECURITY_LOG_LEVEL=warn
APP_LOG_LEVEL=info
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# ===========================================
# JVM 설정 (프로덕션 최적화)
# ===========================================
JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/tmp

# ===========================================
# 모니터링 데이터 저장 경로
# ===========================================
PROMETHEUS_DATA_PATH=/opt/solebid/data/prometheus

# ===========================================
# SSL/TLS 설정 (HTTPS 사용 시)
# ===========================================
# SSL_CERT_PATH=/etc/ssl/certs/your-domain.crt
# SSL_KEY_PATH=/etc/ssl/private/your-domain.key

# ===========================================
# 백업 설정
# ===========================================
# BACKUP_S3_BUCKET=your-backup-bucket
# BACKUP_RETENTION_DAYS=30

# ===========================================
# 보안 설정
# ===========================================
# 방화벽에서 다음 포트만 허용:
# - 80 (HTTP)
# - 443 (HTTPS)
# - 22 (SSH, 관리용)
# 
# 내부 포트는 Docker 네트워크에서만 접근:
# - 8080 (Backend)
# - 6379 (Redis)
# - 9090 (Prometheus)

# ===========================================
# 프로덕션 배포 체크리스트
# ===========================================
# □ 모든 비밀번호와 키를 안전한 값으로 변경
# □ 도메인 설정 완료
# □ SSL 인증서 설정 완료
# □ 방화벽 규칙 설정 완료
# □ 백업 정책 수립 완료
# □ 모니터링 알림 설정 완료
# □ 로그 로테이션 설정 완료
# □ 정기 보안 업데이트 계획 수립

# ===========================================
# SSL/HTTPS 설정 (프로덕션)
# ===========================================
# HTTPS 활성화 (프로덕션에서는 항상 true)
NGINX_SSL_ENABLED=true

# SSL 인증서 경로
# Let's Encrypt 사용 시 자동으로 /etc/letsencrypt/live/도메인/ 에 생성됨
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# 도메인 설정 (Let's Encrypt 인증서 발급용)
DOMAIN=your-domain.com
EMAIL=admin@your-domain.com

# ===========================================
# OAuth2 리다이렉트 URI (HTTPS)
# ===========================================
# 프로덕션에서는 반드시 HTTPS 사용
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/callback/google
KAKAO_REDIRECT_URI=https://your-domain.com/auth/callback/kakao
